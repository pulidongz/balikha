# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — all ignored except the example templates
.env*
!.env.example
!.env.production.example
!.env.backup.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local config
.claude/

# user-uploaded product images (local prototype storage)
/public/uploads/

# Claude Code process artifacts — kept locally, not source-controlled.
# Committed docs/ holds app/feature/ops docs only (see docs/runbooks/).
# Plans, handoffs, specs, and the ticket backlog stay local.
/docs/plans/
/docs/superpowers/
/docs/TICKETS.md

# dev-mode rendered emails (captured by sendEmail's no-send path)
/.dev-mail/


# brainstorming visual-companion artifacts
/.superpowers/
