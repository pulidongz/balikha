{
  "name": "balikha",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node bin/build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.development db/seed/index.ts",
    "db:reset": "drizzle-kit push --force && tsx --env-file=.env.development db/seed/index.ts",
    "email:test": "tsx --env-file=.env.development db/scripts/send-test-email.tsx",
    "email:preview:notifications": "tsx --env-file=.env.development db/scripts/preview-notification-emails.tsx",
    "orders:tick": "tsx --env-file=.env.development db/scripts/orders-tick.ts",
    "admin:bootstrap": "tsx --env-file=.env.development db/scripts/bootstrap-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@base-ui/react": "^1.4.1",
    "@marsidev/react-turnstile": "^1.5.2",
    "@react-email/render": "^2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "disposable-email-domains": "^1.0.62",
    "drizzle-orm": "^0.45.2",
    "image-size": "^2.0.2",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.11",
    "next": "16.2.4",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^6",
    "resend": "^6",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
