# Copy this file to .env.development and fill in real values.
# Never commit .env.development — it is gitignored.

# Local Postgres (matches docker-compose.yml in Phase 2 of balikha-plan.md)
DATABASE_URL="postgres://balikha:balikha_dev@localhost:5432/balikha"

# Better Auth — generate a real secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-a-32-byte-base64-secret"
# In dev, Caddy serves https on :8443 and proxies to the Next dev server on
# :3000 — see Caddyfile + docker-compose.yml.
#
# Pretty URL (preferred): https://dev.balikha.art:8443
#   Resolves to 127.0.0.1 via a Cloudflare A record (DNS only) or /etc/hosts.
#   Works with Google OAuth (Google rejects *.localhost in redirect URIs but
#   accepts public-TLD subdomains).
#
# Plain Caddy (no Google OAuth): https://balikha.localhost:8443
# Direct (bypass Caddy, no TLS):  http://localhost:3000
#
# All three are accepted by Better Auth's CSRF Origin check (see lib/auth.ts).
BETTER_AUTH_URL="https://dev.balikha.art:8443"

# Public app URL (NEXT_PUBLIC_ prefix is required so it ships to the browser).
NEXT_PUBLIC_APP_URL="https://dev.balikha.art:8443"

# S3-compatible storage. In dev, MinIO via docker-compose.yml. In prod,
# Cloudflare R2 — endpoint looks like https://<account-id>.r2.cloudflarestorage.com
# and S3_PUBLIC_URL_BASE is your R2.dev URL or custom image domain.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_ACCESS_KEY_ID="balikha_dev"
S3_SECRET_ACCESS_KEY="balikha_dev_secret"
S3_BUCKET="balikha-images"
S3_PUBLIC_URL_BASE="http://localhost:9000/balikha-images"

# Messaging — rate limits. Optional; these are the built-in defaults.
# Tune post-deploy without a code change.
MESSAGING_NEW_THREADS_PER_BUYER_PER_24H=1
MESSAGING_MAX_MESSAGES_PER_USER_PER_DAY=50
MESSAGING_MAX_MESSAGES_PER_THREAD_PER_MINUTE=3

# Google OAuth. OPTIONAL in dev — when both are set, the "Continue with
# Google" button appears on /sign-in and /sign-up. When either is missing,
# the dev server still boots and email/password sign-in works unchanged.
# Useful for CI runs and for contributors who haven't yet set up a Google
# Cloud project.
#
# Set up: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs for local dev (register both — Google rejects
# *.localhost redirect URIs, so the public-TLD pretty URL is the primary
# path; plain localhost is kept as a fallback for contributors who haven't
# set up the dev subdomain):
#   https://dev.balikha.art:8443/api/auth/callback/google   (primary)
#   http://localhost:3000/api/auth/callback/google          (fallback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Transactional email (Resend). RESEND_API_KEY is optional in dev;
# EMAIL_FROM and EMAIL_REPLY_TO are required (the Zod schema rejects
# missing values). When RESEND_API_KEY is absent, sendEmail() runs in
# dev-mode (renders + logs the HTML, never actually sends). When
# NODE_ENV is also not 'production', the same dev behavior applies even
# if RESEND_API_KEY is set.
#
# To send real email from local dev (e.g., for AC verification):
#   NODE_ENV=production npm run email:test -- your@gmail.com
#
# Set up: https://resend.com → Add Domain → balikha.art → verify in DNS
RESEND_API_KEY=
EMAIL_FROM=hello@balikha.art
EMAIL_REPLY_TO=support@balikha.art

# Cloudflare Turnstile bot challenge (ticket #25).
# Create a widget at https://dash.cloudflare.com → Turnstile → Add Widget.
# Set NEXT_PUBLIC_TURNSTILE_SITE_KEY from the "Site Key" and
# TURNSTILE_SECRET_KEY from the "Secret Key".
# Both are required — the server fails at boot if either is absent.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Static-admin bootstrap (ticket #26). OPTIONAL — the dev server and
# `next build` boot fine without them (the env schema marks both .optional()).
# Set them, then run `npm run admin:bootstrap` to ensure a real, loggable-into
# admin account exists (role='admin', email verified). The script throws if
# either is unset when invoked. ADMIN_PASSWORD must be at least 8 characters.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Sentry error tracking (ticket #34). OPTIONAL — leave empty in dev.
# Sentry.init is gated on NODE_ENV=production, so even with a DSN set the
# dev server never sends events (no dev noise, protects the free-tier quota).
# In production this value is build-inlined from the GitHub Actions repo
# variable NEXT_PUBLIC_SENTRY_DSN (see release.yml), NOT from this file.
# The DSN is non-secret (Project Settings → Client Keys (DSN) in Sentry).
NEXT_PUBLIC_SENTRY_DSN=
