# Copy this file to .env.development and fill in real values.
# Never commit .env.development — it is gitignored.

# Local Postgres (matches docker-compose.yml in Phase 2 of balikha-plan.md)
DATABASE_URL="postgres://balikha:balikha_dev@localhost:5432/balikha"

# Better Auth — generate a real secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-a-32-byte-base64-secret"
# In dev, Caddy serves https on :8443 and proxies to the Next dev server
# on :3000 — see Caddyfile + docker-compose.yml.
BETTER_AUTH_URL="https://balikha.localhost:8443"

# Public app URL (NEXT_PUBLIC_ prefix is required so it ships to the browser).
NEXT_PUBLIC_APP_URL="https://balikha.localhost:8443"

# S3-compatible storage. In dev, MinIO via docker-compose.yml. In prod,
# Cloudflare R2 — endpoint looks like https://<account-id>.r2.cloudflarestorage.com
# and S3_PUBLIC_URL_BASE is your R2.dev URL or custom image domain.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_ACCESS_KEY_ID="balikha_dev"
S3_SECRET_ACCESS_KEY="balikha_dev_secret"
S3_BUCKET="balikha-images"
S3_PUBLIC_URL_BASE="http://localhost:9000/balikha-images"
