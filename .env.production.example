# Balikha production environment — template for /etc/balikha/production.env
# On the box: copy to /etc/balikha/production.env, fill <...>, `chmod 600`,
# `chown balikha-app:balikha-app`. NEVER commit the filled-in file.

NODE_ENV=production
LOG_LEVEL=info

# Postgres — self-hosted on the box, localhost only (4A 80-postgres.sh).
# <DB_PASSWORD> = the value set during 4A (in your password manager).
DATABASE_URL=postgres://balikha:<DB_PASSWORD>@127.0.0.1:5432/balikha

# Better Auth — generate a NEW secret: openssl rand -base64 32
BETTER_AUTH_SECRET=<32+ byte base64 secret>
BETTER_AUTH_URL=https://balikha.art
NEXT_PUBLIC_APP_URL=https://balikha.art

# Cloudflare R2 (bucket balikha-prod, APAC). Token: R2 → Manage API Tokens
# (Object Read & Write, scoped to balikha-prod).
S3_ENDPOINT=https://30d8e334acd6a66be73c7d0442f5a5c9.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=<r2 access key id>
S3_SECRET_ACCESS_KEY=<r2 secret access key>
S3_BUCKET=balikha-prod
S3_PUBLIC_URL_BASE=https://images.balikha.art

# Transactional email (Resend). Prod key; balikha.art verified in Resend.
RESEND_API_KEY=<prod resend api key>
EMAIL_FROM=hello@balikha.art
EMAIL_REPLY_TO=support@balikha.art

# Google OAuth — OPTIONAL. If enabling prod Google sign-in, create prod
# creds with redirect URI https://balikha.art/api/auth/callback/google.
# GOOGLE_CLIENT_ID=<prod client id>
# GOOGLE_CLIENT_SECRET=<prod client secret>

# Order / messaging tunables — OPTIONAL (env.ts defaults apply if omitted):
# ORDER_SELLER_RESPONSE_TIMEOUT_HOURS=48
# ORDER_BUYER_AUTO_CONFIRM_DAYS=14

# Sentry error tracking (ticket #34). NOT set here — NEXT_PUBLIC_SENTRY_DSN
# is build-inlined from the GitHub Actions repo variable of the same name
# (release.yml), so it ships baked into the build. Source-map upload uses
# the build-only vars SENTRY_ORG / SENTRY_PROJECT (repo variables) and
# SENTRY_AUTH_TOKEN (repo secret) — also GitHub-side, never on the box.
# See docs/runbooks/8a-error-tracking.md.
