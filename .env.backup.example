# Balikha backup credentials — template for /etc/balikha/backup.env
# On the box: copy to /etc/balikha/backup.env, fill <...>, `chmod 600`,
# `chown root:root`. Loaded by balikha-backup.service. NEVER commit the
# filled-in file. This is a SEPARATE PRIVATE R2 bucket — NOT balikha-prod
# (which is public via images.balikha.art).

# Cloudflare R2 — private backups bucket. Token: R2 → Manage API Tokens
# (Object Read & Write, scoped to balikha-backups).
BACKUP_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
BACKUP_S3_BUCKET=balikha-backups
# awscli reads these standard names directly:
AWS_ACCESS_KEY_ID=<r2 backups access key id>
AWS_SECRET_ACCESS_KEY=<r2 backups secret access key>
AWS_DEFAULT_REGION=auto
