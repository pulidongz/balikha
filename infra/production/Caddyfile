{
	# TLS is served via a Cloudflare Origin Certificate (the `tls` directive in
	# each site block) — NOT Let's Encrypt. The apex is proxied through
	# Cloudflare (orange cloud), which intercepts the ACME HTTP-01 challenge on
	# port 80, so origin ACME no longer works and is intentionally unused.
	#
	# Cloudflare is the only thing that talks to this origin. Mark its edge IP
	# ranges as trusted proxies and read the real visitor IP from the
	# Cf-Connecting-Ip header it sets. `trusted_proxies_strict` means a client
	# hitting the origin directly cannot spoof the header — Caddy only honours it
	# when the TCP peer is a Cloudflare IP. Refresh these ranges from
	# https://www.cloudflare.com/ips-v4/ and /ips-v6/ TOGETHER WITH
	# infra/production/lock-origin-firewall.sh.
	#
	# LOAD-BEARING INVARIANT: the app trusts X-Real-IP unconditionally because
	# Caddy sets it from the trusted Cf-Connecting-Ip and it reaches server code
	# as an inbound request header (proxy.ts passes inbound headers through
	# unchanged); getRequestLogger + Better Auth read it. That is safe ONLY
	# because Caddy is the sole path to 127.0.0.1:3000 — the Next server binds
	# loopback and ufw blocks 80/443 to non-Cloudflare sources. DO NOT expose
	# :3000 directly (no extra published port, no second reverse proxy bypassing
	# Caddy) or client-spoofed X-Real-IP becomes trusted.
	servers {
		client_ip_headers Cf-Connecting-Ip
		trusted_proxies static \
			173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 \
			141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 \
			197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 \
			104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 \
			2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 \
			2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
		trusted_proxies_strict
	}
}

balikha.art {
	tls /etc/caddy/cloudflare-origin.pem /etc/caddy/cloudflare-origin-key.pem
	encode zstd gzip
	# Hard cap on request body size at the reverse-proxy layer. The product-image
	# upload endpoint enforces MAX_IMAGE_BYTES (10 MB) + multipart overhead in
	# application code, but this Caddy cap prevents other endpoints from being
	# targeted with large bodies and stops the upload endpoint from buffering
	# beyond this ceiling before the app-layer check runs.
	request_body {
		max_size 11MB
	}
	# Baseline security headers set at the origin (independent of edge config).
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Lock down powerful browser features the app never uses. Enforced now
		# (safe — nothing here is used, so nothing breaks).
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
		# CSP is REPORT-ONLY for now: it never blocks, it only reports violations,
		# so it cannot break the site. It cannot be safely enforced yet because
		# Next.js App Router injects inline bootstrap scripts that need a
		# per-request nonce (generated in proxy.ts) instead of 'unsafe-inline'.
		# NOTE: this header has no report-uri/report-to, so violations are visible
		# only in each visitor's browser devtools — they are NOT collected
		# centrally. Wiring a reporting endpoint (Sentry security ingest, which is
		# already the connect-src origin, or a first-party /csp-report handler) is
		# a prerequisite for the "collect violations" migration step and is
		# tracked in the CSP-enforcement ticket (#126).
		# Migration path: (1) ship this report-only policy, (2) wire a reporting
		# endpoint + add report-to and watch violations (or validate manually via
		# devtools), tightening the source lists, (3) add nonce generation in
		# proxy.ts and drop 'unsafe-inline' from script-src, (4) rename the header
		# to Content-Security-Policy to enforce. Known origins: Turnstile
		# (challenges.cloudflare.com), Sentry ingest (*.ingest.sentry.io), R2
		# images (images.balikha.art).
		Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://images.balikha.art; connect-src 'self' https://*.ingest.sentry.io; frame-src 'self' https://challenges.cloudflare.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
	}
	reverse_proxy 127.0.0.1:3000 {
		header_up Host {host}
		header_up X-Forwarded-Proto https
		# {client_ip} is the real visitor (Cf-Connecting-Ip), validated against
		# trusted_proxies above — never Cloudflare's edge IP.
		header_up X-Real-IP {client_ip}
		header_up X-Forwarded-For {client_ip}
		# Mint a request id at the edge so Caddy + app logs correlate
		# (proxy.ts reuses x-request-id, else mints its own).
		header_up X-Request-Id {http.request.uuid}
	}
}

www.balikha.art {
	tls /etc/caddy/cloudflare-origin.pem /etc/caddy/cloudflare-origin-key.pem
	redir https://balikha.art{uri} permanent
}
