# Copy to infra/production/build.env and fill the NEXT_PUBLIC_* values with the
# REAL production values, then `set -a; source build.env; set +a` before
# `npm run build`. smart-deploy.sh does this for you.
#
# Fetch the two non-secret repo variables with:
#   gh variable get NEXT_PUBLIC_TURNSTILE_SITE_KEY
#   gh variable get NEXT_PUBLIC_SENTRY_DSN
#
# --- Inlined into the client bundle — MUST be the real prod values ---
NEXT_PUBLIC_APP_URL=https://balikha.art
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_SENTRY_DSN=
# --- Validated at build time by env.ts but never connected to (dummies) ---
BETTER_AUTH_URL=https://balikha.art
DATABASE_URL=postgres://ci:ci@localhost:5432/ci
BETTER_AUTH_SECRET=release-build-dummy-secret-32-chars-minimum
S3_ENDPOINT=https://example.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=dummy
S3_SECRET_ACCESS_KEY=dummy
S3_BUCKET=balikha-prod
S3_PUBLIC_URL_BASE=https://images.balikha.art
EMAIL_FROM=hello@balikha.art
EMAIL_REPLY_TO=support@balikha.art
TURNSTILE_SECRET_KEY=release-build-dummy-turnstile-secret
